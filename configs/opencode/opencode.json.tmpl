{
  "$schema": "https://opencode.ai/config.json",
  "theme": "{{ .Theme }}",
  "agent": {
    "build": {
      "color": "#fe8019"
    },
    "plan": {
      "color": "#d3869b"
    },
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "color": "#8ec07c"
    }
  },
  "permission": {
    "read": {
      "*": "allow",

      "./.env": "deny",
      "./.env.*": "deny",
      "**/.env": "deny",
      "**/envs/*.js": "deny",
      "./secrets/**": "deny",

      "*.pem": "deny",
      "*.key": "deny",
      "*.env": "deny",

      "**/id_rsa": "deny",
      "**/id_ed25519": "deny"
    },

    "bash": {
      "*": "allow",

      "terraform apply *": "deny",

      "kubectl delete *": "deny",
      "kubectl apply *": "deny",

      "aws *": "deny",
      "gcloud *": "deny",
      "az *": "deny",

      "rm -rf *": "deny",
      "sudo *": "deny"
    },

    "edit": {
      "*": "allow",

      ".git/**": "deny",
      ".claude/**": "deny"
    }
  },
  "formatter": {
    "prettier": {
      "command": ["npx", "prettier", "--write", "$FILE"],
      "extensions": [".js", ".ts", ".jsx", ".tsx"]
    },
    "python-format": {
      "command": ["sh", "-c", "isort \"$FILE\" && black --quiet \"$FILE\""],
      "extensions": [".py"]
    },
    "go-format": {
      "command": ["sh", "-c", "goimports -w \"$FILE\" && gofumpt -w \"$FILE\""],
      "extensions": [".go"]
    },
    "clang-format": {
      "command": ["clang-format", "-i", "$FILE"],
      "extensions": [".c", ".h", ".cpp", ".hpp"]
    },
    "stylua": {
      "command": ["stylua", "$FILE"],
      "extensions": [".lua"]
    }
  }
}
