{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "theme": "custom:default",
  "permissions": {
    "mode": "acceptEdits",
    "allow": [
      "Bash(go *)",
      "Bash(gofmt *)",
      "Bash(golangci-lint *)",
      "Bash(python *)",
      "Bash(pytest *)",
      "Bash(pip *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(tsc *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git commit -m *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Read",
      "Edit",
      "Bash(go test *)",
      "Bash(go run *)",
      "Bash(go mod *)",
      "Bash(make *)",
      "Bash(poetry *)",
      "Bash(uv *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(pnpm *)",
      "Bash(nx *)",
      "Bash(turbo *)",
      "Bash(vitest *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(terraform apply *)",
      "Bash(kubectl delete *)",
      "Bash(kubectl apply *)",
      "Bash(aws *)",
      "Bash(gcloud *)",
      "Bash(az *)",
      "Read(*.pem)",
      "Read(*.key)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Read(*.env)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Edit(.git/**)",
      "Edit(.claude/**)"
    ]
  },
  "env": {
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 2
  }
}
