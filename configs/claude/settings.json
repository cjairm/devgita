{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "theme": "custom:default",
  "permissions": {
    "allow": [
      "Bash(go *)",
      "Bash(gofmt *)",
      "Bash(golangci-lint *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pytest *)",
      "Bash(pip *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(tsc *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(make *)",
      "Bash(poetry *)",
      "Bash(uv *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(pnpm *)",
      "Bash(nx *)",
      "Bash(turbo *)",
      "Bash(vitest *)",
      "Bash(tail *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(cd *)",
      "Bash(source *)",
      "Bash(cat *)",
      "Read",
      "Edit"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(terraform apply *)",
      "Bash(kubectl delete *)",
      "Bash(kubectl apply *)",
      "Bash(aws *)",
      "Bash(gcloud *)",
      "Bash(az *)",
      "Read(*.pem)",
      "Read(*.key)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Read(*.env)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Edit(.git/**)",
      "Edit(.claude/**)"
    ],
    "mode": "acceptEdits"
  },
  "env": {
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 2
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/format.sh"
          }
        ]
      }
    ]
  }
}
