# ============================================================================
# Devgita Shell Configuration
# Auto-generated from template - DO NOT EDIT MANUALLY
# ============================================================================

# Core Tools
# ----------------------------------------------------------------------------
{{if .Mise}}
# Mise - Polyglot runtime manager
if command -v mise &> /dev/null; then
  eval "$(mise activate zsh)"
fi
{{end}}

{{if .Zoxide}}
# Zoxide - Smarter cd command
if command -v zoxide &> /dev/null; then
  eval "$(zoxide init zsh)"
fi
{{end}}

# Shell Enhancements
# ----------------------------------------------------------------------------
{{if .ZshAutosuggestions}}
# Zsh Autosuggestions - Fish-like autosuggestions
{{if .IsMac}}
if [[ -f $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]]; then
    source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
fi
{{else}}
if [[ -f /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]]; then
    source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
fi
{{end}}
{{end}}

{{if .ZshSyntaxHighlighting}}
# Zsh Syntax Highlighting - Fish-like syntax highlighting
{{if .IsMac}}
if [[ -f $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]]; then
    source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi
{{else}}
if [[ -f /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]]; then
    source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi
{{end}}
{{end}}

# Theme
# ----------------------------------------------------------------------------
{{if .Powerlevel10k}}
# Powerlevel10k - Fast and flexible Zsh theme
{{if .IsMac}}
if [[ -f $(brew --prefix)/share/powerlevel10k/powerlevel10k.zsh-theme ]]; then
    source $(brew --prefix)/share/powerlevel10k/powerlevel10k.zsh-theme
fi
{{else}}
if [[ -f ~/powerlevel10k/powerlevel10k.zsh-theme ]]; then
    source ~/powerlevel10k/powerlevel10k.zsh-theme
elif [[ -f /usr/share/powerlevel10k/powerlevel10k.zsh-theme ]]; then
    source /usr/share/powerlevel10k/powerlevel10k.zsh-theme
fi
{{end}}
{{end}}

# ============================================================================
# Devgita Functions & Aliases
# ============================================================================
{{if .ExtendedCapabilities}}
# Extended capabilities — dge is a thin wrapper over `dg task`
dge() {
  if [[ $# -eq 0 ]]; then
    dg task --help
    return
  fi
  dg task "$@"
}
{{end}}

{{if .Fzf}}
# File system
alias ff="fzf --preview 'bat --style=numbers --color=always {}'"
{{end}}

# quick edits
alias edit-zsh="nvim ~/.zshrc"
alias edit-ohmyzsh="nvim ~/.oh-my-zsh"
alias edit-tmux="nvim ~/.tmux.conf"
alias edit-nvim="nvim ~/.config/nvim/init.lua"

# Directories
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Tools
{{if .LazyGit}}
alias lzg='lazygit'
{{end}}
{{if .LazyDocker}}
alias lzd='lazydocker'
{{end}}

{{if .Neovim}}
# Neovim
alias n='nvim'
{{if .Fzf}}
alias ns="fd --type f --hidden --exclude .git | fzf-tmux -p  --reverse | xargs nvim"
{{end}}
{{end}}

# Git
alias g='git'
alias gcm='git commit -m'
alias gcam='git commit -a -m'
alias gcad='git commit -a --amend'

{{if .Tmux}}
# Tmux
alias tml="tmux list-sessions"
alias tmk="tmux kill-session -t"
alias tms="tmux switch-client -t"
alias tmkall="tmux kill-server"
alias tmclear="clear && tmux clear-history && clear"
tmn() {
    local session_name="$1"
    local path="${2:-$HOME}"
    /usr/local/bin/tmux new-session -d -s "$session_name" -c "$path"
    /usr/local/bin/tmux switch-client -t "$session_name"
}
{{end}}

# Compression
compress() { tar -czf "${1%/}.tar.gz" "${1%/}"; }
alias decompress="tar -xzf"

{{if .Mise}}
# Mise
alias mx="mise x --"
{{end}}

{{if .Zoxide}}
# ---- Zoxide (better cd) ----
alias cd="z"
{{end}}

{{if .Eza}}
# ---- Eza (better ls) ----
alias ls='eza -lh --group-directories-first --icons'
alias lsa='ls -a'
alias lt='eza --tree --level=2 --long --icons --git'
alias lta='lt -a'
{{end}}

{{if .Eza}}
# ---- Bat (better cat) ----
alias cat="bat"
{{end}}

{{if .Opencode}}
alias oc=opencode
{{end}}

{{if .Claude}}
alias cc="CLAUDE_CODE_NO_FLICKER=1 claude"
{{end}}
# ============================================================================
# End of Devgita Configuration
# ============================================================================
